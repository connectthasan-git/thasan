rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
        get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    match /free-resources/{resourceId}/{fileName} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /projects/uploads/{projectId}/{fileName} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /users/profile/{userId}/{fileName} {
      allow read: if true;
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    match /courses/videos/{courseId}/{fileName} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /certificates/{certId}/{fileName} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
