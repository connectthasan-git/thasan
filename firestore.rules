rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    function isApprovedCourseCreator() {
      return isSignedIn()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isCourseCreatorApproved == true;
    }

    function isPublicDocument() {
      return !("isPublished" in resource.data) || resource.data.isPublished == true;
    }

    function isPublicInternship() {
      return isPublicDocument()
        && (!("isActive" in resource.data) || resource.data.isActive == true);
    }

    match /users/{userId} {
      allow read, create, update, delete: if isAdmin()
        || (isSignedIn() && request.auth.uid == userId);
    }

    match /freelancerProfiles/{profileId} {
      allow read: if true;
      allow create: if isAdmin()
        || (isSignedIn() && request.resource.data.userId == request.auth.uid);
      allow update, delete: if isAdmin()
        || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    match /clientProjects/{projectId} {
      allow read: if true;
      allow create: if isAdmin()
        || (isSignedIn() && request.resource.data.clientId == request.auth.uid);
      allow update, delete: if isAdmin()
        || (isSignedIn() && resource.data.clientId == request.auth.uid);
    }

    match /projectBids/{bidId} {
      allow read: if true;
      allow create: if isAdmin()
        || (isSignedIn() && request.resource.data.bidderId == request.auth.uid);
      allow update, delete: if isAdmin()
        || (isSignedIn() && resource.data.bidderId == request.auth.uid);
    }

    match /payments/{paymentId} {
      allow read: if isAdmin()
        || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isAdmin()
        || (isSignedIn() && request.resource.data.userId == request.auth.uid);
      allow update, delete: if isAdmin()
        || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    match /startups/{startupId} {
      allow read: if true;
      allow create: if isAdmin()
        || (isSignedIn() && request.resource.data.founderId == request.auth.uid);
      allow update, delete: if isAdmin()
        || (isSignedIn() && resource.data.founderId == request.auth.uid);
    }

    match /communityPosts/{postId} {
      allow read: if true;
      allow create: if isAdmin()
        || (isSignedIn() && request.resource.data.authorId == request.auth.uid);
      allow update, delete: if isAdmin()
        || (isSignedIn() && resource.data.authorId == request.auth.uid);
    }

    match /communityComments/{commentId} {
      allow read: if true;
      allow create: if isAdmin()
        || (isSignedIn() && request.resource.data.authorId == request.auth.uid);
      allow update, delete: if isAdmin()
        || (isSignedIn() && resource.data.authorId == request.auth.uid);
    }

    match /communityGroups/{groupId} {
      allow read: if true;
      allow create: if isAdmin()
        || (isSignedIn() && request.resource.data.createdBy == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    match /communityCourses/{courseId} {
      // Anyone can read approved courses; instructors and admins can always read their own
      allow read: if resource.data.status == "approved"
        || (isSignedIn() && resource.data.instructorId == request.auth.uid)
        || isAdmin();

      // Any signed-in user can submit pending courses; approved creators can publish directly
      allow create: if isAdmin()
        || (isSignedIn()
          && request.resource.data.instructorId == request.auth.uid
          && (
            request.resource.data.status == "pending"
            || (request.resource.data.status == "approved" && isApprovedCourseCreator())
          ));

      // Instructors (and admins) can freely update or delete their courses
      allow update, delete: if isAdmin()
        || (isSignedIn() && resource.data.instructorId == request.auth.uid);
    }

    match /communityCoursePurchases/{purchaseId} {
      allow read: if isAdmin()
        || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isAdmin()
        || (isSignedIn() && request.resource.data.userId == request.auth.uid);
    }

    match /enrollments/{enrollmentId} {
      allow read: if isAdmin()
        || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isAdmin()
        || (isSignedIn() && request.resource.data.userId == request.auth.uid);
      allow update, delete: if isAdmin()
        || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    match /internshipApplications/{applicationId} {
      allow read: if isAdmin()
        || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isAdmin()
        || (isSignedIn() && request.resource.data.userId == request.auth.uid);
      allow update, delete: if isAdmin()
        || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    match /notifications/{notificationId} {
      allow read: if isAdmin()
        || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isAdmin()
        || (isSignedIn() && request.resource.data.userId == request.auth.uid);
      allow update, delete: if isAdmin()
        || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    match /courses/{courseId} {
      allow read: if isPublicDocument() || isAdmin();
      allow write: if isAdmin();
    }

    match /internships/{internshipId} {
      allow read: if isPublicInternship() || isAdmin();
      allow write: if isAdmin();
    }

    match /studentBuilds/{buildId} {
      allow read: if true;
      allow create: if isAdmin()
        || (isSignedIn() && request.resource.data.userId == request.auth.uid);
      allow update, delete: if isAdmin()
        || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    match /freeResources/{resourceId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /events/{eventId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /clubs/{clubId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
